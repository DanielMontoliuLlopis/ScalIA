# === Postgres (servicio docker) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_ESTO_password_fuerte
POSTGRES_DB=growthOS

# DATABASE_URL apunta al servicio "postgres" del compose.
# Usa la MISMA password de arriba.
DATABASE_URL=postgresql+asyncpg://postgres:CAMBIA_ESTO_password_fuerte@postgres:5432/growthOS
REDIS_URL=redis://redis:6379

# === OpenAI ===
OPENAI_API_KEY=sk-proj-...

# === Auth ===
JWT_SECRET=CAMBIA_ESTO_secreto_largo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# === Búsqueda ===
BRAVE_API_KEY=BSA...

# === Meta ===
META_APP_ID=...
META_APP_SECRET=...

# === CORS ===
ALLOWED_ORIGINS=https://scalia.hacelerix.com

# === Frontend (build args) ===
VITE_API_URL=https://api.scalia.hacelerix.com
VITE_WS_URL=wss://api.scalia.hacelerix.com
